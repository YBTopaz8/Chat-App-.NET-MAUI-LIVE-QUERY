<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="LiveQueryChatAppMAUI.MainPage"
    x:Name="myPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:Vm="clr-namespace:LiveQueryChatAppMAUI.ViewModel"
    xmlns:local="clr-namespace:LiveQueryChatAppMAUI"
    xmlns:seedrModels="clr-namespace:YBSeedrClient.SeedrModels;assembly=YBSeedrClient"
    xmlns:syncf="http://schemas.syncfusion.com/maui/toolkit"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:DataType="Vm:HomePageViewModel"
    >

    <Grid
        Grid.Row="0"
        ColumnDefinitions="*"
        RowDefinitions="auto,auto,*"
        RowSpacing="15"
        >

        <Grid
            Grid.Row="0"
            Margin="10"
            ColumnDefinitions="*,*"
            ColumnSpacing="10"
            >
            <Button
                Grid.Column="0"
                Command="{Binding InitializeCommand}"
                FontSize="24"
                Text="Files"
                />

            <Button Grid.Column="1" Text="Tasks" />
        </Grid>
        <Grid
            Grid.Row="1"
            Grid.Column="0"
            BackgroundColor="Black"
            ColumnDefinitions="*,auto"
            RowDefinitions="auto,*"
            >


            <Editor
                x:Name="LinkEditor"
                Grid.Column="0"
                Focused="LinkEditor_Focused"
                TextChanged="LinkEditor_TextChanged"
                Unfocused="LinkEditor_Unfocused"
                />

            <HorizontalStackLayout Grid.Column="1">
                <Button
                    BackgroundColor="DarkSlateBlue"
                    Command="{Binding AddMagnetCommand}"
                    CommandParameter="{Binding Text, Source={x:Reference LinkEditor}}"
                    Text="Add"
                    TextColor="White"
                    />
            </HorizontalStackLayout>
        </Grid>

        <CollectionView
            Grid.Row="2"
            Grid.Column="0"
            BackgroundColor="Transparent"
            Header="Main Folder"
            ItemsSource="{Binding RootFolder.Folders}"
            >
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="seedrModels:SeedrFolderItem">

                    <Grid ColumnDefinitions="*,auto,auto,auto,auto">

                        <Label Grid.Column="0" Text="{Binding Path}" />
                        <Label Grid.Column="1" Text="{Binding FilesCount}" />
                        <Label Grid.Column="2" Text="{Binding LastUpdate}" />
                        <Label Grid.Column="3" Text="{Binding Size}" />
                        <Button Grid.Column="4" Text="More" />
                    </Grid>



                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>


    </Grid>
</ContentPage>
